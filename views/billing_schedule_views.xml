<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_billing_schedule_list" model="ir.ui.view">
        <field name="name">billing.schedule.list</field>
        <field name="model">billing.schedule</field>
        <field name="arch" type="xml">
            <list string="Billing Schedules">
                <field name="name"/>
                <field name="period"/>
                <field name="simulation"/>
                <field name="active"/>
                <field name="total_credit_amount"/>
            </list>
        </field>

    </record>

    <record id="view_billing_schedule_form" model="ir.ui.view">
        <field name="name">billing.schedule.form</field>
        <field name="model">billing.schedule</field>
        <field name="arch" type="xml">
            <form string="Billing Schedule">
                <header>
                    <button name="action_manual_billing"
                            string="Billing"
                            type="object" class="btn-primary"
                            confirm="Are you sure you want to create billing?"/>
                </header>
                <sheet>
                    <group>
                        <group string="Basic Information">
                            <field name="name"/>
                            <field name="simulation"/>
                            <field name="period"/>
                            <field name="active"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="total_credit_amount"/>
                        </group>

                        <group string="Other Info">
                            <field name="restrict_customer_ids"
                                   widget="many2many_tags"/>
                            <field name="recurring_subscription_ids"
                                   widget="many2many_tags"/>
                        </group>
                    </group>


                    <div name="button_box" position="inside">
                        <button class="oe_stat_button"
                                type="object"
                                icon="fa-refresh"
                                name="action_view_recurring_subscriptions">
                            <field name="recurring_subscription_count" string="Subscriptions" widget="statinfo"/>
                        </button>
                    </div>
                    <notebook>
                        <page string="Credits">
                            <field name="credit_ids">
                                <list>
                                    <field name="recurring_subscription_id"/>
                                    <field name="partner_id"/>
                                    <field name="credit_amount"/>
                                    <field name="period_date"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                </sheet>
                <chatter/>
            </form>
        </field>

    </record>

    <record id="action_billing_schedule" model="ir.actions.act_window">
        <field name="name">Billing Schedules</field>
        <field name="res_model">billing.schedule</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>