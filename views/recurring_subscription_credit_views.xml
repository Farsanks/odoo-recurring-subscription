<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_recurring_subscription_credit_list" model="ir.ui.view">
        <field name="name">recurring.subscription.credit.list</field>
        <field name="model">recurring.subscription.credit</field>
        <field name="arch" type="xml">
            <list string="Recurring Subscription Credits">
                <field name="id" string="Credit Reference"/>
                <field name="recurring_subscription_id"/>
                <field name="partner_id"/>
                <field name="credit_amount"/>
                <field name="period_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_recurring_subscription_credit_form" model="ir.ui.view">
        <field name="name">recurring.subscription.credit.form</field>
        <field name="model">recurring.subscription.credit</field>
        <field name="arch" type="xml">
            <form string="Recurring Subscription Credit">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,confirmed,first_approved,fully_approved,rejected"
                           options="{'clickable':1}"/>
                </header>
                <sheet>
                    <group>
                        <group string="Credit Information">
                            <field name="recurring_subscription_id"/>
                            <field name="partner_id"/>
                            <field name="company_id"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="establishment_id"/>
                        </group>
                        <group string="Other Info">
                            <field name="due_date"/>
                            <field name="subscription_amount"/>
                            <field name="credit_amount"/>
                            <field name="period_date"/>
                        </group>
                    </group>

                </sheet>
                <chatter/>
            </form>
        </field>
    </record>


    <record id="action_recurring_subscription_credit" model="ir.actions.act_window">
        <field name="name">Subscriptions Credits</field>
        <field name="res_model">recurring.subscription.credit</field>
        <field name="view_mode">list,form</field>
    </record>


</odoo>