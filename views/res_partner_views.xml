<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_res_partner_form_inherit" model="ir.ui.view">
        <field name="name">res.partner.form.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='category_id']" position="after">
                    <field name="establishment_id"/>
                    <field name="account_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_partner_account_id_list" model="ir.ui.view">
        <field name="name">partner.account.id.list</field>
        <field name="model">partner.account.id</field>
        <field name="arch" type="xml">
            <list string="Partners With Account ID" create="0">
                <field name="partner_id"/>
                <field name="account_id"/>
            </list>
        </field>
    </record>


    <record id="action_partner_account_id" model="ir.actions.act_window">
        <field name="name">Partners With Account ID</field>
        <field name="res_model">partner.account.id</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_partner_account_id_list"/>
    </record>
</odoo>