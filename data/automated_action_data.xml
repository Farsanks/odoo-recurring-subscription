<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <record id="email_template_subscription_done" model="mail.template">
            <field name="name">Recurring Subscription -Done</field>
            <field name="model_id" ref="model_recurring_subscription"/>
            <field name="subject">Your Recurring subscription</field>
            <field name="email_to">{{object.partner_id.email}}</field>
            <field name="body_html" type="html">
                <p>Hi<t t-out=" object.partner_id.name"/>,
                </p>
                <p>This is a reminder for your subscription<t t-out=" object.name"/>,</p>
                <p>
                    <strong>Please pay the amount or renew.</strong>
                </p>
                <br/>
                <p>Best regards,<br/>Farsan
                </p>
            </field>
        </record>

        <record id="action_server_subscription_done" model="ir.actions.server">
            <field name="name">Send Email-Subscription done</field>
            <field name="model_id" ref="model_recurring_subscription"/>
            <field name="state">code</field>
            <field name="code">
template = env.ref('recurring_subscription.email_template_subscription_done')
for record in records:
    if record.partner_id.email:
        template.send_mail(record.id,force_send=True)
        record.message_post(
                body=f'Email sent to {record.partner_id.name} ({record.partner_id.email}) -Subscription {record.name} is Done',
                message_type='email',
                subtype_xmlid='mail.mt_note',)
            </field>
        </record>


        <record id="automated_action_subscription_done" model="base.automation">
            <field name="name">Sent Email On Subscription Done</field>
            <field name="model_id" ref="model_recurring_subscription"/>
            <field name="trigger">on_write</field>
            <field name="filter_domain">[('state','=','done')]</field>
            <field name="action_server_ids" eval="[(4, ref('action_server_subscription_done'))]"/>
        </record>
    </data>
</odoo>


