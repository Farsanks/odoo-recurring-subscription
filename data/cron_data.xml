<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_auto_invoice" model="ir.cron">
            <field name="name">Auto Invoice</field>
            <field name="model_id" ref="model_recurring_subscription"/>
            <field name="code">model.action_auto_invoice()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d 09:00:00')"/>
        </record>
    </data>
</odoo>
